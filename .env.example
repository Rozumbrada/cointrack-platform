# ─── Server ─────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=dev          # dev | staging | production

# ─── Postgres ───────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cointrack
POSTGRES_USER=cointrack
POSTGRES_PASSWORD=cointrack

# ─── MinIO / S3 ─────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=cointrack
S3_SECRET_KEY=cointrack123
S3_BUCKET=cointrack-files
S3_REGION=eu-central-1

# ─── Auth / JWT ─────────────────────────────────────────────────────
# 256-bit hex (vygeneruj: openssl rand -hex 32)
JWT_SECRET=change_me_to_random_256_bits_in_production
JWT_ISSUER=cointrack
JWT_AUDIENCE=cointrack-clients
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ─── Email (Resend v produkci / Mailhog v dev) ──────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@cointrack.cz

# ─── OAuth Google ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── Banking aggregator (Sprint 6) ──────────────────────────────────
# Používáme abstrakci BankingProvider — stačí vyplnit toho, kterého používáš.
# Preferujeme GoCardless BAD, Enable Banking jako záložní variantu.

# GoCardless Bank Account Data — https://bankaccountdata.gocardless.com/
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Enable Banking — https://enablebanking.com/
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY_PATH=

# Salt Edge — https://www.saltedge.com/
# Pending tier (sandbox/fake banks zdarma) stačí pro dev. Production tier vyžaduje compliance.
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v6
SALT_EDGE_RETURN_URL=${PUBLIC_WEB_URL}/bank/return
SALT_EDGE_CALLBACK_URL=${PUBLIC_API_URL}/api/v1/bank/webhook

# Který provider je aktivní: gocardless | enablebanking | saltedge | fio_only
BANKING_PROVIDER=saltedge

# ─── Stripe (Sprint 8) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CLOUD_MONTHLY=
STRIPE_PRICE_CLOUD_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# ─── Sentry ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Public URLs ────────────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WEB_URL=http://localhost:3000
