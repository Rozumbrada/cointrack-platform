# Cointrack Caddy reverse proxy
# Auto SSL přes Let's Encrypt. HTTP→HTTPS redirect automaticky.

{
    email founder@cointrack.cz
    # Výchozí providera = Let's Encrypt.
    # Pokud chceš staging (pro testování bez rate limitu), odkomentuj:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ─── API ────────────────────────────────────────────────────────────
api.cointrack.cz {
    reverse_proxy api:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Rate limiting je v Ktor vrstvě (per-endpoint), zde jen globální basic
    @health path /health
    reverse_proxy @health api:8080

    # Response compression
    encode gzip zstd

    # Logging
    log {
        output file /data/access-api.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}

# ─── MinIO (public file access přes presigned URLs) ─────────────────
files.cointrack.cz {
    # CORS pro PUT/GET z webu — bez nich browser blokuje cross-origin PUT
    # z cointrack.cz a uživatel vidí "Failed to fetch" v scan flow.
    #
    # `defer` jako sub-directive uvnitř bloku zajišťuje, že hlavičky se
    # přidají těsně před zápisem response — přežije jak respond, tak
    # reverse_proxy. Allow-Origin: * funguje pro non-credentialed requesty
    # (= náš upload flow s presigned URL, který nepoužívá cookies).
    header {
        defer
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, PUT, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, x-amz-content-sha256, x-amz-date, x-amz-meta-*, x-amz-acl"
        Access-Control-Expose-Headers "ETag"
        Access-Control-Max-Age "3600"
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options "nosniff"
        -Server
    }

    # Preflight OPTIONS — okamžitá 204 (header middleware výš doplní CORS).
    @options method OPTIONS
    respond @options 204

    reverse_proxy minio:9000 {
        header_up Host {host}
    }

    encode gzip
}
