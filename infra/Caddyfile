# Cointrack Caddy reverse proxy
# Auto SSL přes Let's Encrypt. HTTP→HTTPS redirect automaticky.

{
    email founder@cointrack.cz
    # Výchozí providera = Let's Encrypt.
    # Pokud chceš staging (pro testování bez rate limitu), odkomentuj:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ─── API ────────────────────────────────────────────────────────────
api.cointrack.cz {
    reverse_proxy api:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Rate limiting je v Ktor vrstvě (per-endpoint), zde jen globální basic
    @health path /health
    reverse_proxy @health api:8080

    # Response compression
    encode gzip zstd

    # Logging
    log {
        output file /data/access-api.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}

# ─── MinIO (public file access přes presigned URLs) ─────────────────
files.cointrack.cz {
    # CORS pro PUT/GET z webu — bez nich browser blokuje cross-origin PUT
    # z cointrack.cz a uživatel vidí "Failed to fetch" v scan flow.
    #
    # Použitý vzorec: matchery na Origin, pak per-line `header @matcher X Y`
    # s `defer` (= aplikuj na response NEZÁVISLE na tom, jestli respond,
    # reverse_proxy nebo cokoliv jiného odpověď generuje). `Vary: Origin`
    # informuje proxy/CDN že response závisí na Origin.
    @corsProd header Origin "https://cointrack.cz"
    @corsDev header Origin "http://localhost:3000"

    header @corsProd defer Access-Control-Allow-Origin "https://cointrack.cz"
    header @corsProd defer Access-Control-Allow-Methods "GET, PUT, POST, OPTIONS"
    header @corsProd defer Access-Control-Allow-Headers "Content-Type, Authorization, x-amz-content-sha256, x-amz-date, x-amz-meta-*, x-amz-acl"
    header @corsProd defer Access-Control-Expose-Headers "ETag"
    header @corsProd defer Access-Control-Max-Age "3600"
    header @corsProd defer Vary "Origin"

    header @corsDev defer Access-Control-Allow-Origin "http://localhost:3000"
    header @corsDev defer Access-Control-Allow-Methods "GET, PUT, POST, OPTIONS"
    header @corsDev defer Access-Control-Allow-Headers "Content-Type, Authorization, x-amz-content-sha256, x-amz-date, x-amz-meta-*, x-amz-acl"
    header @corsDev defer Access-Control-Expose-Headers "ETag"
    header @corsDev defer Access-Control-Max-Age "3600"
    header @corsDev defer Vary "Origin"

    # Preflight OPTIONS — okamžitá 204. `defer` u header @corsProd výš znamená,
    # že CORS hlavičky se přidají i na tuto response.
    @options method OPTIONS
    respond @options 204

    reverse_proxy minio:9000 {
        header_up Host {host}
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options "nosniff"
        -Server
    }

    encode gzip
}
